{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/ar", "destination": "/ar.html" },
    { "source": "/about", "destination": "/pages/about.html" },
    { "source": "/map", "destination": "/pages/map.html" },
    { "source": "/sustainability", "destination": "/pages/sustainability.html" },
    { "source": "/pages/ar", "destination": "/ar.html" },
    { "source": "/pages/about", "destination": "/pages/about.html" },
    { "source": "/pages/map", "destination": "/pages/map.html" },
    { "source": "/pages/sustainability", "destination": "/pages/sustainability.html" }
  ]
}
